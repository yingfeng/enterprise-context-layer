{
  "name": "AI Agent System Architecture",
  "version": "2.0",
  "description": "多形状+多箭头综合示例",
  "flow": {
    "nodes": [
      { "id": "user", "label": "用户输入", "type": "start", "shape": "circle" },
      { "id": "gateway", "label": "API Gateway", "type": "process", "shape": "rect" },
      { "id": "orchestrator", "label": "Orchestrator", "type": "process", "shape": "hexagon" },
      { "id": "llm", "label": "LLM (DeepSeek)", "type": "process", "shape": "double_rect" },
      { "id": "memory", "label": "Vector Store", "type": "process", "shape": "cylinder" },
      { "id": "rag", "label": "RAG 文档", "type": "process", "shape": "document" },
      { "id": "chat", "label": "对话输出", "type": "end", "shape": "speech" },
      { "id": "decision", "label": "需要工具?", "type": "decision", "shape": "diamond" },
      { "id": "toolA", "label": "搜索工具", "type": "process", "shape": "rect" },
      { "id": "toolB", "label": "计算工具", "type": "process", "shape": "rect" },
      { "id": "deploy", "label": "部署脚本", "type": "end", "shape": "terminal" }
    ],
    "edges": [
      { "source": "user", "target": "gateway", "label": "HTTP请求", "flowType": "control" },
      { "source": "gateway", "target": "orchestrator", "label": "路由", "flowType": "control" },
      { "source": "orchestrator", "target": "llm", "label": "推理请求", "flowType": "write" },
      { "source": "llm", "target": "memory", "label": "查询记忆", "flowType": "read" },
      { "source": "memory", "target": "llm", "label": "相关上下文", "flowType": "data" },
      { "source": "llm", "target": "rag", "label": "检索知识库", "flowType": "read" },
      { "source": "rag", "target": "llm", "label": "检索结果", "flowType": "data" },
      { "source": "llm", "target": "decision", "label": "分析结果", "flowType": "control" },
      { "source": "decision", "target": "toolA", "label": "是: 搜索", "flowType": "control" },
      { "source": "decision", "target": "toolB", "label": "是: 计算", "flowType": "async" },
      { "source": "toolA", "target": "llm", "label": "搜索结果", "flowType": "feedback" },
      { "source": "toolB", "target": "llm", "label": "计算结果", "flowType": "feedback" },
      { "source": "llm", "target": "chat", "label": "生成回复", "flowType": "write" },
      { "source": "orchestrator", "target": "deploy", "label": "异步部署", "flowType": "async" }
    ]
  }
}
